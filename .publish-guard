# =============================================================
# .publish-guard — Sperrmuster für Pre-Commit-Hook
# =============================================================
# Jede Zeile ist ein grep -E (Extended Regex) Pattern.
# Wenn ein staged File eines dieser Muster enthält,
# wird der Commit blockiert.
#
# Neue Muster einfach als Zeile hinzufügen.
# Kommentare (#) und Leerzeilen werden ignoriert.
# =============================================================

# --- Interne IP-Adressen (Netz 192.168.2.x) ---
192\.168\.2\.[0-9]+

# --- Benutzernamen ---
backup-user
\bjk@

# --- Hostnamen ---
\bfailover-host\b
\bbackup-host\b
\bprimary-host\b

# --- E-Mail / Domain ---
example
notify@

# --- SMTP-Provider ---
smtp\.example\.de
\bStrato\b
\bstrato\b

# --- Dateisystem-Pfade ---
/home/user/Dokumente/PVAnlage
/home/user/Documents/PVAnlage
/home/user/Dokumente/PVAnlage

# --- Geräte-Seriennummern (Fritz!DECT AIN) ---
00000.0000000
