[Unit]
Description=PV-System: Persist RAM-DB vor Shutdown/Reboot
DefaultDependencies=no
After=local-fs.target
Before=shutdown.target reboot.target halt.target poweroff.target

[Service]
Type=oneshot
User=admin
WorkingDirectory=/home/admin/Dokumente/PVAnlage/pv-system
ExecStart=/bin/bash /home/admin/Dokumente/PVAnlage/pv-system/scripts/persist_on_shutdown.sh
TimeoutStartSec=120

[Install]
WantedBy=halt.target reboot.target poweroff.target
